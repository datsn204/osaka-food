# Backend Environment Variables
# Copy to .env and update

PORT=5000

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=osaka_food

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_make_it_long_and_random

# Upload (optional)
UPLOAD_MAX_SIZE=5242880

